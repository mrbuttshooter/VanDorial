# Python
gencall/**/__pycache__/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Runtime data / secrets (never commit)
*.db
*.sqlite
*.log
.env
gencall/logs/
gencall/media/*.wav

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Built NOC console — COMMITTED on purpose so native/offline installs (which
# have no Node) serve the UI. The Docker build regenerates it (stage 1).
# gencall/web/console/   <- intentionally tracked

# Offline wheelhouse — COMMITTED on purpose so a clone / the GitHub zip is a
# complete air-gapped install bundle (Python 3.10 linux wheels). Regenerate with:
#   pip download --only-binary=:all: --platform manylinux_2_17_x86_64 \
#     --platform manylinux_2_28_x86_64 --python-version 3.10 --abi cp310 \
#     --implementation cp -r requirements.txt -d vendor/wheelhouse
#   (+ explicit: uvloop sniffio exceptiongroup — markers drop these off-Linux)

# Release zips (build artifacts, never commit)
*.zip

# Tooling / editor
.playwright-mcp/
.DS_Store
*.local

# Proprietary sale-codes deck (full international rate-deck zone/code map).
# Kept OUT of the public repo; delivered to the box as a data file. The committed
# sample (sale_codes.sample.csv) is enough for tests + a demo run.
gencall/scripts/data/sale_codes.csv
