# GenCall environment configuration.
# Copy to `.env` (which is git-ignored) and fill in real secrets.
# docker-compose reads this file automatically.

# --- PostgreSQL credentials (consumed by both the db and gencall services) ---
POSTGRES_DB=gencall
POSTGRES_USER=gencall
# REQUIRED — pick a strong password. Compose will refuse to start without it.
POSTGRES_PASSWORD=

# --- GenCall database selection ---
# Use the bundled postgres service by default. Set to "sqlite" for local/dev.
GENCALL_DB_ENGINE=postgresql

# Alternatively, provide a full SQLAlchemy URL (overrides the GENCALL_PG_* vars):
# GENCALL_DATABASE_URL=postgresql://user:pass@host:5432/gencall
