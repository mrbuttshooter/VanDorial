<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">
<!--
  GenCall v2 - Loop Answer UAS (permanent answering leg) - design §4.1/§4.2.

  Built on SIPp's proven built-in 'uas' skeleton (validated on sipp 3.6.1). One
  long-lived UAS bound to the SIP port; answers calls returning from MADA, echoes
  media two-way (-rtp_echo at launch), waits for the BYE.

  Per-call <log> lines (-trace_logs) feed the CallRecord tail-parser. B-side
  duration = t_bye_received - t_200ok_sent. source_ip is captured from the top Via
  host of the INVITE (SIPp has no [senderip] keyword) and recorded for visibility
  only; the host firewall (and the upstream switch) are the trust boundary.

  IMPORTANT — all <log> actions live INSIDE <recv> elements (a standalone <nop>
  between a <send> and the next message makes sipp 3.6 mis-handle the incoming
  message and abort). So t_200ok_sent is logged on the ACK recv (one RTT after
  the 200 leaves — sipp <send> cannot carry an action) and t_bye_received on the
  BYE recv. The answered-call max-duration guard is the literal recv-BYE timeout
  (7200000 ms = 2 h); if no BYE arrives the recv times out and SIPp frees the
  channel.
-->
<scenario name="GenCall - Loop UAS">

  <!-- Wait for INVITE (t_invite_received); parse from/to numbers + source IP. -->
  <recv request="INVITE" crlf="true">
    <action>
      <ereg regexp="sip:([^@>;]+)@" search_in="hdr" header="From:" assign_to="trash,from_number" />
      <ereg regexp="sip:([^@>;]+)@" search_in="hdr" header="To:" assign_to="trash,to_number" />
      <ereg regexp="SIP/2.0/[A-Za-z0-9]+[ \t]+([^:; \t\r\n]+)" search_in="hdr" header="Via:" assign_to="trash,source_ip" />
      <log message="loop_uas direction=in call_id=[call_id] from_number=[$from_number] to_number=[$to_number] source_ip=[$source_ip] event=invite t_invite_received=[clock_tick]" />
    </action>
  </recv>

  <!-- 180 Ringing. -->
  <send>
    <![CDATA[
      SIP/2.0 180 Ringing
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Length: 0
    ]]>
  </send>

  <!-- 200 OK with SDP → B-side clock STARTS (logged on ACK below). -->
  <send retrans="500">
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=GenCall 53655765 2353687637 IN IP[local_ip_type] [local_ip]
      s=GenCall UAS
      c=IN IP[media_ip_type] [media_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 8 101
      a=rtpmap:8 PCMA/8000
      a=rtpmap:101 telephone-event/8000
      a=fmtp:101 0-15
      a=ptime:20
      a=sendrecv
    ]]>
  </send>

  <!-- ACK (optional). Log t_200ok_sent here (≈ 200-sent + 1 RTT). -->
  <recv request="ACK" optional="true" rtd="true" crlf="true">
    <action>
      <log message="loop_uas direction=in call_id=[call_id] from_number=[$from_number] to_number=[$to_number] source_ip=[$source_ip] event=answer t_200ok_sent=[clock_tick]" />
    </action>
  </recv>

  <!-- Wait for BYE → B-side clock STOPS (t_bye_received). Literal 2 h guard. -->
  <recv request="BYE" timeout="7200000">
    <action>
      <log message="loop_uas direction=in call_id=[call_id] from_number=[$from_number] to_number=[$to_number] source_ip=[$source_ip] event=bye t_bye_received=[clock_tick]" />
    </action>
  </recv>

  <!-- 200 to the BYE. -->
  <send>
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Length: 0
    ]]>
  </send>

  <!-- Keep the slot briefly so a re-sent BYE can be answered (built-in idiom). -->
  <timewait milliseconds="4000" />

  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200" />
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000, 30000" />

</scenario>
