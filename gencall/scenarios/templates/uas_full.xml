<?xml version="1.0" encoding="ISO-8859-1" ?>
<!--
  GenCall - Full UAS: Answer calls with RTP, handle re-INVITE, OPTIONS, BYE
  This is the SIPp XML equivalent of the incoming_call.py script.
-->
<scenario name="GenCall - Full UAS">

  <!-- ── Wait for INVITE ─────────────────────────────────────────────── -->
  <recv request="INVITE" crlf="true">
    <action>
      <ereg regexp="sip:([^@]+)@" search_in="hdr" header="From:" assign_to="trash,caller_user" />
      <ereg regexp="sip:([^@]+)@" search_in="hdr" header="To:" assign_to="trash,callee_user" />
    </action>
  </recv>

  <!-- ── 100 Trying ──────────────────────────────────────────────────── -->
  <send>
    <![CDATA[
      SIP/2.0 100 Trying
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0
    ]]>
  </send>

  <!-- ── 180 Ringing ─────────────────────────────────────────────────── -->
  <send>
    <![CDATA[
      SIP/2.0 180 Ringing
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Length: 0
    ]]>
  </send>

  <!-- ── Simulate ring time (1-10 sec random) ────────────────────────── -->
  <pause milliseconds="3000" />

  <!-- ── 200 OK with SDP + RTP ───────────────────────────────────────── -->
  <send retrans="500">
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=GenCall 53655765 2353687637 IN IP[local_ip_type] [local_ip]
      s=GenCall UAS
      c=IN IP[media_ip_type] [media_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 0 8 101
      a=rtpmap:0 PCMU/8000
      a=rtpmap:8 PCMA/8000
      a=rtpmap:101 telephone-event/8000
      a=fmtp:101 0-15
      a=ptime:20
      a=sendrecv
    ]]>
  </send>

  <!-- ── Wait for ACK ────────────────────────────────────────────────── -->
  <recv request="ACK" rtd="true" crlf="true" />

  <!-- ── Start RTP echo (play back received media) ───────────────────── -->
  <nop>
    <action>
      <exec rtp_stream="pauseaudiofile.pcap,loop" />
    </action>
  </nop>

  <!-- ── Mid-call: Handle BYE, OPTIONS, re-INVITE ────────────────────── -->
  <label id="mid_call" />

  <!-- Wait for next message (BYE, OPTIONS, or re-INVITE) -->
  <recv request="." regexp_match="true" timeout="300000"
        ontimeout="call_timeout" crlf="true">
    <action>
      <ereg regexp="(.*)" search_in="hdr" header="CSeq:" assign_to="recv_cseq" />
      <strcmp assign_to="is_bye" variable="[last_Request-URI]" value=".*BYE.*" />
      <strcmp assign_to="is_options" variable="[last_Request-URI]" value=".*OPTIONS.*" />
      <strcmp assign_to="is_invite" variable="[last_Request-URI]" value=".*INVITE.*" />
    </action>
  </recv>

  <!-- ── Handle BYE ──────────────────────────────────────────────────── -->
  <recv request="BYE" optional="true">
    <action>
      <exec rtp_stream="stop" />
    </action>
  </recv>

  <send optional="true">
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0
    ]]>
  </send>

  <!-- ── Handle OPTIONS (keep-alive) ─────────────────────────────────── -->
  <recv request="OPTIONS" optional="true" />

  <send optional="true" next="mid_call">
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Allow: INVITE, ACK, BYE, CANCEL, OPTIONS
      Content-Length: 0
    ]]>
  </send>

  <!-- ── Handle re-INVITE ────────────────────────────────────────────── -->
  <recv request="INVITE" optional="true" />

  <send optional="true">
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=GenCall 53655765 2353687638 IN IP[local_ip_type] [local_ip]
      s=GenCall UAS
      c=IN IP[media_ip_type] [media_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 0 8 101
      a=rtpmap:0 PCMU/8000
      a=rtpmap:8 PCMA/8000
      a=rtpmap:101 telephone-event/8000
      a=fmtp:101 0-15
      a=ptime:20
      a=sendrecv
    ]]>
  </send>

  <recv request="ACK" optional="true" next="mid_call" />

  <!-- ── Timeout fallback ────────────────────────────────────────────── -->
  <label id="call_timeout" />

  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200" />
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000, 30000" />

</scenario>
