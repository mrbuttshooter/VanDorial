    "/api/fleet/loops/{run_id}": {
      "get": {
        "description": "Combined loop_stats across all member nodes of a loop fleet run.\n\nPolls each member node's GET /api/loops/{campaign_id} for its latest\nloop_stats and sums minutes-out/in + completion across nodes (design \u00a77\nstage 9). Per-node snapshots are echoed so the console can drill in.",
        "operationId": "fleet_loop_view_api_fleet_loops__run_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "run_id",
            "required": true,
            "schema": {
              "title": "Run Id",
              "type": "integer"
            }
          },
